# =============================================================================
# MailZen Coolify environment template
# -----------------------------------------------------------------------------
# Copy this file to: deploy/coolify/.env.coolify
# Then fill in every value marked with  ← REQUIRED
# Optional sections can be left commented out.
# =============================================================================

# -----------------------------------------------------------------------------
# Domain configuration
# -----------------------------------------------------------------------------
# Your apex domain (dashboard + API).  www.MAILZEN_DOMAIN = marketing site.
MAILZEN_DOMAIN=mail.example.com           # ← REQUIRED

# -----------------------------------------------------------------------------
# Frontend build-time public env vars (compiled into Next.js bundle)
# IMPORTANT: In Coolify UI, set these as BUILD VARIABLES, not just env vars.
# They must be available at docker build time, not just at runtime.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://mail.example.com/graphql  # ← REQUIRED
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_ENABLE_EMAIL_WARMUP=true
NEXT_PUBLIC_ENABLE_SMART_REPLIES=true
NEXT_PUBLIC_ENABLE_EMAIL_TRACKING=true
NEXT_PUBLIC_DEFAULT_THEME=system
# URL that the marketing www site links to for "Open App"
NEXT_PUBLIC_APP_URL=https://mail.example.com

# -----------------------------------------------------------------------------
# Database (Dockerized PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=mailzen
POSTGRES_USER=mailzen
POSTGRES_PASSWORD=replace_with_strong_postgres_password   # ← REQUIRED

# -----------------------------------------------------------------------------
# Redis (Dockerized)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
AI_AGENT_GATEWAY_REDIS_URL=redis://redis:6379
AI_AGENT_GATEWAY_USE_REDIS=true

# -----------------------------------------------------------------------------
# Auth / JWT secrets  (all must be >= 32 characters)
# -----------------------------------------------------------------------------
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars_please_replace  # ← REQUIRED
JWT_EXPIRATION=86400
REFRESH_TTL_SECONDS=2592000
OAUTH_STATE_SECRET=replace_with_another_long_random_secret_min_32_chars   # ← REQUIRED

# Session cookie settings for HTTPS.
MAILZEN_SESSION_COOKIE_NAME=token
MAILZEN_SESSION_COOKIE_SAMESITE=lax
MAILZEN_SESSION_COOKIE_SECURE=true

# -----------------------------------------------------------------------------
# TypeORM settings
# -----------------------------------------------------------------------------
# DATABASE_URL is constructed dynamically in docker-compose from POSTGRES_* vars.
# You don't need to set it here — it's set in the compose environment block.
TYPEORM_SYNCHRONIZE=false
TYPEORM_RUN_MIGRATIONS=true
TYPEORM_POOL_MAX=20
TYPEORM_IDLE_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Mail / provider secrets encryption  (must be >= 32 chars)
# -----------------------------------------------------------------------------
SECRETS_KEY=replace_with_strong_32_plus_char_secret_for_internal_encryption       # ← REQUIRED
PROVIDER_SECRETS_KEYRING=default:replace_with_strong_32_plus_char_provider_secret # ← REQUIRED
PROVIDER_SECRETS_ACTIVE_KEY_ID=default

# -----------------------------------------------------------------------------
# AI platform
# -----------------------------------------------------------------------------
AI_AGENT_PLATFORM_URL=http://ai-agent-platform:8100
AI_AGENT_PLATFORM_REQUIRED=false
AI_AGENT_PLATFORM_CHECK_ON_STARTUP=true
# Shared secret between backend and the AI platform container.
AI_AGENT_PLATFORM_KEY=replace_with_random_agent_platform_key   # ← REQUIRED

# AI agent LLM provider: "claude" | "openai" | "rule_based" (default = rule_based = free)
AGENT_PLATFORM_AGENT_LLM_PROVIDER=rule_based
AGENT_PLATFORM_AGENT_LLM_API_KEY=
AGENT_PLATFORM_AGENT_LLM_MODEL=
AGENT_PLATFORM_DEFAULT_LOCALE=en-IN
AGENT_PLATFORM_MAX_MESSAGE_CHARS=3000
AGENT_PLATFORM_LATENCY_WARN_MS=1200
AGENT_PLATFORM_ERROR_RATE_WARN_PERCENT=5.0

# -----------------------------------------------------------------------------
# Google OAuth (optional — needed if users sign in with Google)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://mail.example.com/auth/google/callback
GOOGLE_PROVIDER_REDIRECT_URI=https://mail.example.com/email-integration/google/callback

# -----------------------------------------------------------------------------
# Microsoft / Outlook OAuth (optional)
# -----------------------------------------------------------------------------
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=https://mail.example.com/auth/microsoft/callback
OUTLOOK_PROVIDER_REDIRECT_URI=https://mail.example.com/email-integration/microsoft/callback

# -----------------------------------------------------------------------------
# SMTP defaults (optional — for transactional emails)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Smart replies — LLM provider (enable exactly one or leave all false)
# -----------------------------------------------------------------------------
SMART_REPLY_USE_OPENAI=false
# SMART_REPLY_OPENAI_API_KEY=sk-...
# SMART_REPLY_OPENAI_MODEL=gpt-4o-mini

SMART_REPLY_USE_ANTHROPIC=false
# SMART_REPLY_ANTHROPIC_API_KEY=sk-ant-...
# SMART_REPLY_ANTHROPIC_MODEL=claude-3-5-haiku-latest

SMART_REPLY_USE_AZURE_OPENAI=false
# SMART_REPLY_AZURE_OPENAI_API_KEY=
# SMART_REPLY_AZURE_OPENAI_ENDPOINT=
# SMART_REPLY_AZURE_OPENAI_DEPLOYMENT=

# AI email auto-classification (requires an OpenAI key above)
ENABLE_AI_AUTO_CLASSIFY=false

# -----------------------------------------------------------------------------
# Billing — Stripe (optional)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_BUSINESS=price_...

# -----------------------------------------------------------------------------
# Billing — Razorpay (optional; comment out if using Stripe only)
# -----------------------------------------------------------------------------
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...
# RAZORPAY_PLAN_ID_PRO=plan_...
# RAZORPAY_PLAN_ID_BUSINESS=plan_...

# -----------------------------------------------------------------------------
# SMS / OTP — Twilio (optional; set to "console" to log OTPs to stdout)
# -----------------------------------------------------------------------------
MAILZEN_SMS_PROVIDER=console
# MAILZEN_SMS_TWILIO_ACCOUNT_SID=
# MAILZEN_SMS_TWILIO_AUTH_TOKEN=
# MAILZEN_SMS_TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Error tracking — Sentry (optional but strongly recommended for production)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.05
# SENTRY_PROFILES_SAMPLE_RATE=0.05
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
