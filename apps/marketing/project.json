{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "marketing",
  "projectType": "application",
  "sourceRoot": "apps/marketing",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/marketing",
        "command": "npm run dev"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/marketing",
        "command": "npm run build"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/marketing",
        "command": "npm run start"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/marketing",
        "command": "npm run lint"
      }
    }
  }
}
